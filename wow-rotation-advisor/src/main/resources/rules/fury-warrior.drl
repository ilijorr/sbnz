package rules;

import com.faks.sbnz.wow_rotation_advisor.model.FuryWarriorState;
import com.faks.sbnz.wow_rotation_advisor.model.AbilityState;
import com.faks.sbnz.wow_rotation_advisor.model.TargetState;
import com.faks.sbnz.wow_rotation_advisor.facts.*;

rule "FW-L1-AvatarActive"
when
    FuryWarriorState(avatarActive == true, avatarRemainingSeconds > 0)
then
    insert(new AvatarActive());
end

rule "FW-L1-EnragedState"
when
    FuryWarriorState(enrageActive == true, enrageRemainingSeconds > 0)
then
    insert(new EnragedState());
end

rule "FW-L1-EnrageExpiring"
when
    FuryWarriorState(enrageActive == true, enrageRemainingSeconds < 1.5)
then
    insert(new EnrageExpiring());
end

rule "FW-L1-RecklessnessActive"
when
    FuryWarriorState(recklessnessActive == true)
then
    insert(new RecklessnessActive());
end

rule "FW-L1-ExecutePhase"
when
    FuryWarriorState()
    TargetState(hpPercent < 20.0)
then
    insert(new ExecutePhase());
end

rule "FW-L1-SDProcActive"
when
    FuryWarriorState(suddenDeathProcActive == true)
then
    insert(new SDProcActive());
end

rule "FW-L1-RagingBlowChargeCap"
when
    FuryWarriorState()
    AbilityState(name == "Raging Blow", chargesAvailable == 2, maxCharges == 2)
then
    insert(new RagingBlowChargeCap());
end

rule "FW-L2-RampageUrgent-EnrageExpiring"
when
    EnrageExpiring()
    not RampageUrgent()
then
    insert(new RampageUrgent("Enrage isce — hitna obnova"));
end

rule "FW-L2-RampageUrgent-RageHigh"
when
    RageHighRisk()
    not RampageUrgent()
then
    insert(new RampageUrgent("Rage 80+ — overcap rizik"));
end

rule "FW-L2-EmergencyRageDump"
when
    RampageUrgent()
    EnragedState()
then
    insert(new EmergencyRageDump());
end

rule "FW-L2-BurstWindowOpportunity"
when
    EnragedState()
    RecklessnessReady()
then
    insert(new BurstWindowOpportunity());
end

rule "FW-L2-ExecutePriorityActive-Phase"
when
    ExecutePhase()
    not ExecutePriorityActive()
then
    insert(new ExecutePriorityActive());
end

rule "FW-L2-ExecutePriorityActive-SD"
when
    SDProcActive()
    not ExecutePriorityActive()
then
    insert(new ExecutePriorityActive());
end

rule "FW-L3-Rampage-EnrageExpiring" salience 140
when
    EnrageExpiring()
    FuryWarriorState(primaryResource >= 80)
then
    insert(new Recommendation("Rampage", 140, "HIGH", "Enrage isce — hitna obnova Enrage-a"));
end

rule "FW-L3-Rampage-ReckBurst" salience 130
when
    RecklessnessActive()
    RageHighRisk()
    FuryWarriorState(primaryResource >= 80)
then
    insert(new Recommendation("Rampage", 130, "HIGH", "Recklessness aktivan + Rage visok — troši u burst-u"));
end

rule "FW-L3-Execute-SuddenDeath" salience 120
when
    SDProcActive()
    FuryWarriorState()
    AbilityState(name == "Execute", cooldownRemaining == 0.0)
then
    insert(new Recommendation("Execute", 120, "HIGH", "Sudden Death proc — besplatni Execute"));
end

rule "FW-L3-Recklessness-Burst" salience 110
when
    BurstWindowOpportunity()
    AbilityState(name == "Recklessness", cooldownRemaining == 0.0)
then
    insert(new Recommendation("Recklessness", 110, "HIGH", "Enrage + Recklessness spreman — otvori burst window"));
end

rule "FW-L3-Avatar-WithReck" salience 108
when
    RecklessnessActive()
    AvatarReady()
then
    insert(new Recommendation("Avatar", 108, "HIGH", "Recklessness aktivan — aktiviraj Avatar za maks stetu (20s buff)"));
end

rule "FW-L3-Avatar-General" salience 72
when
    AvatarReady()
    not RecklessnessActive()
    not AvatarActive()
then
    insert(new Recommendation("Avatar", 72, "MEDIUM", "Avatar dostupan — sacekaj Recklessness za sinhronizaciju ili koristi odmah"));
end

rule "FW-L3-Rampage-Urgent" salience 90
when
    RampageUrgent($reason: reason)
    not EmergencyRageDump()
    FuryWarriorState(primaryResource >= 80)
then
    insert(new Recommendation("Rampage", 90, "HIGH", $reason));
end

rule "FW-L3-Execute-Phase" salience 80
when
    ExecutePriorityActive()
    not SDProcActive()
    FuryWarriorState(primaryResource >= 25)
    AbilityState(name == "Execute", cooldownRemaining == 0.0)
then
    insert(new Recommendation("Execute", 80, "HIGH", "Execute faza aktivan"));
end

rule "FW-L3-Odyn's-Fury-Burst" salience 105
when
    OdynsFuryReady()
    RecklessnessActive()
then
    insert(new Recommendation("Odyn's Fury", 105, "HIGH", "Recklessness aktivan — iskoristi Odyn's Fury za AoE burst"));
end

rule "FW-L3-Bloodthirst-Recklessness-NoEnrage" salience 85
when
    RecklessnessActive()
    not EnragedState()
    AbilityState(name == "Bloodthirst", cooldownRemaining == 0.0)
then
    insert(new Recommendation("Bloodthirst", 85, "HIGH",
        "Recklessness aktivan bez Enrage — Bloodthirst odmah (30% proc Enrage-a)"));
end

rule "FW-L3-RagingBlow-ChargeCap" salience 65
when
    RagingBlowChargeCap()
    not RampageUrgent()
    not EnrageExpiring()
then
    insert(new Recommendation("Raging Blow", 65, "MEDIUM",
        "Raging Blow na max punjenjima — koristi odmah da ne blokiras novi recharge"));
end

rule "FW-L3-Odyn's-Fury-General" salience 75
when
    OdynsFuryReady()
    not RecklessnessActive()
then
    insert(new Recommendation("Odyn's Fury", 75, "MEDIUM", "Odyn's Fury dostupan — sekundarni burst CD"));
end

rule "FW-L3-Bloodthirst-NoEnrage" salience 60
when
    FuryWarriorState()
    not EnragedState()
    not RampageUrgent()
    AbilityState(name == "Bloodthirst", cooldownRemaining == 0.0)
then
    insert(new Recommendation("Bloodthirst", 60, "MEDIUM", "Nema Enrage — Bloodthirst (30% šansa Enrage proca)"));
end

rule "FW-L3-RagingBlow-Filler" salience 50
when
    FuryWarriorState()
    AbilityState(name == "Raging Blow", chargesAvailable > 0)
    not RampageUrgent()
    not BurstWindowOpportunity()
then
    insert(new Recommendation("Raging Blow", 50, "LOW", "Filler — generiši Rage (+12)"));
end
